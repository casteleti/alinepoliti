# ============================================================================
# Variáveis de ambiente — Aline Politi (copie para o servidor; NÃO versionar segredos)
# No Docker, definir em docker-compose.yml (environment:) ou num .env do compose.
# ============================================================================

# ---- Banco de dados (MySQL) ----
DB_HOST=db
DB_NAME=alinepoliti
DB_USER=alinepoliti
DB_PASS=CHANGE_ME
# Só para o container do MySQL:
DB_ROOT_PASS=CHANGE_ME

# ---- Ambiente ----
APP_ENV=prod

# ============================================================================
# Envio de e-mail (formulário de contato)
# Preferência do código: 1) SMTP  ->  2) Resend  ->  3) mail() nativo
# ============================================================================

# ---- Opção A (recomendada): SMTP autenticado da caixa do domínio (Hostinger) ----
# ATENÇÃO: NÃO usar "mail.alinepoliti.com.br" — esse hostname aponta para o VPS do site
# (167.233.105.48), que não tem servidor de e-mail. O servidor de e-mail real é o
# cpl119.main-hosting.eu (151.106.100.137). Config abaixo TESTADA e funcionando:
SMTP_HOST=cpl119.main-hosting.eu
SMTP_PORT=465
SMTP_SECURE=ssl                       # 'ssl' (porta 465) ou 'tls' (porta 587)
SMTP_USER=site@alinepoliti.com.br     # conta que autentica/envia
SMTP_PASS=CHANGE_ME
MAIL_FROM=site@alinepoliti.com.br     # precisa ser = SMTP_USER
MAIL_FROM_NAME=Site Aline Politi
# O destino (quem recebe) é SITE_EMAIL no config.php: atendimento@alinepoliti.com.br

# ---- Opção B (alternativa): Resend (API) — deixe SMTP_* vazios para usar esta ----
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM=Site Aline Politi <contato@alinepoliti.com.br>
