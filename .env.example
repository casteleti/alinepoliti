# ============================================================================
# Variáveis de ambiente — Aline Politi (copie para o servidor; NÃO versionar segredos)
# No Docker, definir em docker-compose.yml (environment:) ou num .env do compose.
# ============================================================================

# ---- Banco de dados (MySQL) ----
DB_HOST=db
DB_NAME=alinepoliti
DB_USER=alinepoliti
DB_PASS=CHANGE_ME
# Só para o container do MySQL:
DB_ROOT_PASS=CHANGE_ME

# ---- Ambiente ----
APP_ENV=prod

# ============================================================================
# Envio de e-mail (formulário de contato)
# Preferência do código: 1) SMTP  ->  2) Resend  ->  3) mail() nativo
# ============================================================================

# ---- Opção A (recomendada): SMTP autenticado da caixa do domínio (cPanel/Hostinger) ----
# cPanel: valores exatos em Email Accounts > Connect Devices > "Secure SSL/TLS Settings".
SMTP_HOST=mail.alinepoliti.com.br
SMTP_PORT=465
SMTP_SECURE=ssl                       # 'ssl' (porta 465) ou 'tls' (porta 587)
SMTP_USER=atendimento@alinepoliti.com.br
SMTP_PASS=CHANGE_ME
MAIL_FROM=atendimento@alinepoliti.com.br
MAIL_FROM_NAME=Site Aline Politi

# ---- Opção B (alternativa): Resend (API) — deixe SMTP_* vazios para usar esta ----
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM=Site Aline Politi <contato@alinepoliti.com.br>
