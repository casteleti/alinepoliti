# Rotas amigáveis → front controller
Options -MultiViews -Indexes
RewriteEngine On

# === Canonicalização 301 — força HTTPS + host canônico (apex, sem www) ===
# Não roda em localhost/dev. Ao forçar HTTPS mantém o host (não quebra previews);
# a consolidação de domínio p/ o Google é feita pela tag canonical (SITE_ORIGIN).
RewriteCond %{HTTP_HOST} !^localhost [NC]
RewriteCond %{HTTP_HOST} !^127\.0\.0\.1 [NC]
RewriteCond %{HTTPS} !=on
RewriteCond %{HTTP:X-Forwarded-Proto} !=https
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# www.alinepoliti.com.br → alinepoliti.com.br (apex é o host canônico; www responde 503)
RewriteCond %{HTTP_HOST} ^www\.alinepoliti\.com\.br [NC]
RewriteRule ^ https://alinepoliti.com.br%{REQUEST_URI} [R=301,L]

# Serve arquivos e pastas reais (assets, etc.) diretamente
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Todo o resto vai para o index.php
RewriteRule ^ index.php [L]

# Compressão (se disponível)
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css application/javascript application/json image/svg+xml application/xml
</IfModule>

# Cache de assets estáticos
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/svg+xml "access plus 30 days"
  ExpiresByType image/jpeg "access plus 30 days"
  ExpiresByType image/png "access plus 30 days"
  ExpiresByType image/webp "access plus 30 days"
  ExpiresByType image/avif "access plus 30 days"
  ExpiresByType text/css "access plus 7 days"
  ExpiresByType application/javascript "access plus 7 days"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# Cabeçalhos de segurança e cache
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
  <FilesMatch "\.(svg|jpg|jpeg|png|webp|avif|woff2|css|js)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
</IfModule>
